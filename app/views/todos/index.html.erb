<% content_for :title, "Todo List" %>

<div class="container mx-auto px-4 py-8">
  <div class="max-w-4xl mx-auto">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-bold text-gray-800">My Todo List</h1>
      <%= link_to "New Todo", new_todo_path, 
          class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded transition-colors" %>
    </div>

    <% if @todos.any? %>
      <div class="bg-white shadow-lg rounded-lg overflow-hidden">
        <% @todos.each_with_index do |todo, index| %>
          <div class="flex items-center p-4 <%= 'border-b border-gray-200' unless index == @todos.count - 1 %> 
                      <%= 'bg-gray-50' if todo.completed? %>">
            
            <!-- Toggle完了ボタン -->
            <%= button_to toggle_todo_path(todo), method: :patch, 
                class: "mr-4 #{todo.completed? ? 'text-green-500' : 'text-gray-400'} hover:text-green-600 transition-colors" do %>
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                <% if todo.completed? %>
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                <% else %>
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm0-2a6 6 0 100-12 6 6 0 000 12z" clip-rule="evenodd"></path>
                <% end %>
              </svg>
            <% end %>
            
            <!-- Todo内容 -->
            <div class="flex-grow">
              <%= link_to todo_path(todo), class: "block hover:bg-gray-100 rounded p-2 transition-colors" do %>
                <h3 class="text-lg font-semibold <%= 'line-through text-gray-500' if todo.completed? %>">
                  <%= todo.title %>
                </h3>
                <% if todo.description.present? %>
                  <p class="text-gray-600 mt-1 <%= 'line-through' if todo.completed? %>">
                    <%= truncate(todo.description, length: 100) %>
                  </p>
                <% end %>
                <p class="text-sm text-gray-400 mt-2">
                  Created <%= time_ago_in_words(todo.created_at) %> ago
                </p>
              <% end %>
            </div>

            <!-- アクションボタン -->
            <div class="flex space-x-2 ml-4">
              <%= link_to "Edit", edit_todo_path(todo), 
                  class: "bg-yellow-500 hover:bg-yellow-600 text-white px-3 py-1 rounded text-sm transition-colors" %>
              <%= button_to "Delete", todo_path(todo), 
                  method: :delete,
                  data: { confirm: "Are you sure?" },
                  class: "bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded text-sm transition-colors border-0" %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- 統計情報 -->
      <div class="mt-6 bg-white shadow rounded-lg p-4">
        <div class="flex justify-between text-sm text-gray-600">
          <span>Total: <%= @todos.count %></span>
          <span>Completed: <%= @todos.completed.count %></span>
          <span>Pending: <%= @todos.pending.count %></span>
        </div>
      </div>
      
    <% else %>
      <div class="text-center py-12">
        <div class="text-gray-400 mb-4">
          <svg class="w-16 h-16 mx-auto" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 8a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 12a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 16a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-700 mb-2">No todos yet!</h3>
        <p class="text-gray-500 mb-4">Get started by creating your first todo.</p>
        <%= link_to "Create your first todo", new_todo_path, 
            class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
