<%= form_with model: todo, local: true, class: "space-y-6" do |form| %>
  <% if todo.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex">
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(todo.errors.count, "error") %> prohibited this todo from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc list-inside">
              <% todo.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_field :title,
        class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500",
        placeholder: "Enter your todo title..." %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_area :description, 
        rows: 4,
        class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500",
        placeholder: "Add more details about your todo (optional)..." %>
  </div>

  <% if todo.persisted? %>
    <div class="flex items-center">
      <%= form.check_box :completed, 
          class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
      <%= form.label :completed, "Mark as completed", 
          class: "ml-2 block text-sm text-gray-700" %>
    </div>
  <% end %>

  <div class="flex justify-between items-center pt-4">
    <div>
      <% if todo.persisted? %>
        <%= link_to "Cancel", todo_path(todo), 
            class: "bg-gray-300 hover:bg-gray-400 text-gray-800 font-medium py-2 px-4 rounded transition-colors" %>
      <% else %>
        <%= link_to "Cancel", todos_path, 
            class: "bg-gray-300 hover:bg-gray-400 text-gray-800 font-medium py-2 px-4 rounded transition-colors" %>
      <% end %>
    </div>
    
    <div>
      <%= form.submit todo.persisted? ? "Update Todo" : "Create Todo",
          class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-6 rounded transition-colors" %>
    </div>
  </div>
<% end %>
