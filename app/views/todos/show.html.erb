<% content_for :title, @todo.title %>

<div class="container mx-auto px-4 py-8">
  <div class="max-w-3xl mx-auto">
    <!-- ナビゲーション -->
    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center">
        <%= link_to todos_path, class: "mr-4 text-gray-600 hover:text-gray-800 transition-colors" do %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        <% end %>
        <h1 class="text-3xl font-bold text-gray-800">Todo Details</h1>
      </div>

      <div class="flex space-x-3">
        <%= link_to "Edit", edit_todo_path(@todo),
            class: "bg-yellow-500 hover:bg-yellow-600 text-white font-medium py-2 px-4 rounded transition-colors" %>
        <%= button_to "Delete", todo_path(@todo),
            method: :delete,
            data: { confirm: "Are you sure you want to delete this todo?" },
            class: "bg-red-500 hover:bg-red-600 text-white font-medium py-2 px-4 rounded transition-colors border-0" %>
      </div>
    </div>

    <!-- メインコンテンツ -->
    <div class="bg-white shadow-lg rounded-lg overflow-hidden">
      <!-- ヘッダー部分 -->
      <div class="px-6 py-4 <%= @todo.completed? ? 'bg-green-50 border-l-4 border-green-500' : 'bg-blue-50 border-l-4 border-blue-500' %>">
        <div class="flex items-start justify-between">
          <div class="flex-grow">
            <h2 class="text-2xl font-bold <%= @todo.completed? ? 'text-green-800 line-through' : 'text-blue-800' %>">
              <%= @todo.title %>
            </h2>
            <div class="flex items-center mt-2 space-x-4">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= @todo.completed? ? 'bg-green-100 text-green-800' : 'bg-blue-100 text-blue-800' %>">
                <%= @todo.completed? ? 'Completed' : 'Pending' %>
              </span>
              <span class="text-sm text-gray-500">
                Created <%= time_ago_in_words(@todo.created_at) %> ago
              </span>
              <% if @todo.updated_at != @todo.created_at %>
                <span class="text-sm text-gray-500">
                  Updated <%= time_ago_in_words(@todo.updated_at) %> ago
                </span>
              <% end %>
            </div>
          </div>

          <!-- Toggle Button -->
          <%= button_to toggle_todo_path(@todo), method: :patch,
              class: "ml-4 #{@todo.completed? ? 'text-green-500 hover:text-green-600' : 'text-blue-500 hover:text-blue-600'} transition-colors" do %>
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
              <% if @todo.completed? %>
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              <% else %>
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm0-2a6 6 0 100-12 6 6 0 000 12z" clip-rule="evenodd"></path>
              <% end %>
            </svg>
          <% end %>
        </div>
      </div>

      <!-- Description -->
      <div class="px-6 py-4">
        <h3 class="text-lg font-semibold text-gray-800 mb-3">Description</h3>
        <% if @todo.description.present? %>
          <div class="prose max-w-none">
            <p class="text-gray-700 leading-relaxed <%= 'line-through text-gray-500' if @todo.completed? %>">
              <%= simple_format(@todo.description) %>
            </p>
          </div>
        <% else %>
          <p class="text-gray-500 italic">No description provided.</p>
        <% end %>
      </div>

      <!-- Timeline/Actions -->
      <div class="px-6 py-4 bg-gray-50 border-t">
        <h3 class="text-lg font-semibold text-gray-800 mb-3">Quick Actions</h3>
        <div class="flex space-x-3">
          <% unless @todo.completed? %>
            <%= button_to "Mark as Completed", toggle_todo_path(@todo), method: :patch,
                class: "bg-green-500 hover:bg-green-600 text-white font-medium py-2 px-4 rounded transition-colors" %>
          <% else %>
            <%= button_to "Mark as Pending", toggle_todo_path(@todo), method: :patch,
                class: "bg-blue-500 hover:bg-blue-600 text-white font-medium py-2 px-4 rounded transition-colors" %>
          <% end %>
          <%= link_to "Edit Todo", edit_todo_path(@todo),
              class: "bg-yellow-500 hover:bg-yellow-600 text-white font-medium py-2 px-4 rounded transition-colors" %>
          <%= link_to "Back to List", todos_path,
              class: "bg-gray-500 hover:bg-gray-600 text-white font-medium py-2 px-4 rounded transition-colors" %>
        </div>
      </div>
    </div>
  </div>
</div>
