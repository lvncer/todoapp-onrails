# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle

# Ignore all environment files (except templates).
/.env*
!/.env.template

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key

/public/packs
/public/packs-test
/node_modules
/yarn-error.log
yarn-debug.log*
.yarn-integrity

# Ignore .DS_Store files on macOS.
.DS_Store

# Ignore Vim swap files
*.swp
*.swo

# Ignore Emacs backup files
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Ignore VS Code settings (optional, remove if you want to share settings)
.vscode/
.history/

# Ignore RubyMine project files
.idea/

# Ignore coverage reports
/coverage/

# Ignore simplecov generated coverage
coverage.json

# Ignore byebug command history
.byebug_history

# Ignore Spring files.
/spring/*.pid

# Ignore bootsnap cache
/tmp/cache/bootsnap*

# Ignore node_modules
node_modules/

# Ignore yarn files
yarn-debug.log*
.yarn-integrity

# Ignore database dumps
*.sql
*.dump

# Ignore Docker volumes data
docker-data/

# Ignore local configuration files
config/database.local.yml
config/secrets.local.yml

# Ignore backup files
*.backup
*.bak
*.orig

# Ignore OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Ignore Linux
*~

# Ignore tags generated by etags/ctags
TAGS
tags
*.tags

# Ignore pow environment settings
.powenv

# Ignore rbenv version file
.ruby-version
.rbenv-version

# Ignore RVM files
.rvmrc

# Ignore Vagrant
.vagrant/
*.box

# Ignore Docker Compose override files
docker-compose.override.yml

# Ignore test artifacts
/spec/tmp
/spec/examples.txt

# Ignore Rails credentials
/config/credentials/*.key

# Ignore precompiled assets
/public/assets/
/public/packs/
/public/packs-test/

# Ignore ActionText Trix editor uploads
/app/assets/builds/

# Ignore Stimulus manifests
/app/assets/builds/

# Ignore compiled CSS from Tailwind (if using)
/app/assets/builds/tailwind.css

# Ignore local environment variables
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore editor configs (optional)
*.sublime-project
*.sublime-workspace

# Ignore RSpec generated files
spec/reports/
spec/tmp/

# Ignore Capybara screenshots
tmp/screenshots/

# Ignore letter_opener emails in development
tmp/letter_opener/

# Ignore Active Storage uploads in development
/storage/

# Ignore log files specific to the app
debug.log
development.log
test.log
production.log

# Ignore temporary ruby files
*.tmp
*.rbc

# Ignore vendor/cache in case someone commits it
vendor/cache/

# Ignore Sassc cache
.sass-cache/

# Ignore Redis dump files
dump.rdb

# Ignore PID files
*.pid

# Ignore any local todo or note files
TODO.local
NOTES.local
notes.txt
